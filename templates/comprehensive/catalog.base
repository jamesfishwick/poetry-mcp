formulas:
  Untitled: ""
views:
  - type: table
    name: Catalog
    filters:
      and:
        - file.inFolder("Poetry/catalog")
    order:
      - file.name
      - file.folder
      - file.links
      - file.tags
      - keywords
      - form
    sort:
      - property: file.name
        direction: ASC
